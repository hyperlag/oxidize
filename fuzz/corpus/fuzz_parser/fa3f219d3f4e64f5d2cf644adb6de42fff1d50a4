public class Power {
    public static long power(long base, int exp) {
        long result = 1;
        for (int i = 0; i < exp; i++) {
            result *= base;
        }
        return result;
    }
    publicvoid main(String[] args) {
        System.out.println(power(2, 10));
        System.out.println(power(4, 5));
    }
}
