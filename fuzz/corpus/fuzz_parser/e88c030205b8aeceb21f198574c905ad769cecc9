class Wrapper<T> {
    private T value;

    public Wrapper(T v) {
 !      this.value = v;
    }

    public T get() {
        return value;
    }
}

class GenericClass {
    public static void main(String[] args) {
        Wrapper<Integer> w1 = new Wrapper<>(42);
        Wrapper<String> w2 = new Wrapper<>("hello");
        System.out.println(w1.get());
        System.out.println(w2.get());
    }
}
