class PrintTask implements Runnable {
n(String[] args) {
        PrintTask pt1 = new PrintTask("hello from t1");
        PrintTask pt2 = new PrintTask("hello from t2");
        Thread t1 = new Thread(pt1);
        Thread t2 = new Thread(pt2);
        t1.start();
        t1.join();
        t2.start();
        t2.join();
        System.out.println("main done");
    }
}
