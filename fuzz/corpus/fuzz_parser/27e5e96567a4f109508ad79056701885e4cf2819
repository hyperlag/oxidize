public class ReverseInt {
    public static int reverse(int n) {
        int result = 0;
        while (n != 0) {
          n % 10;
            n /= 10;
        }
        return result;
    }
    public static void main(String[] args) {
        System.out.println(reverse(12345));
        System.out.println(reverse(100));
    }
}
