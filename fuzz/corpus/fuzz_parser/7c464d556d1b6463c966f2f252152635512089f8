class Vehicle {
    String brand;
    int year;

    Vehicle(String brand, int year) {
        this.brand = brand;
        this.year = year;
    }

    String getBrand() {
        return this.brand;
    }

    int getYear() {
        return this.year;
    }

    String describe() {
        return this.brand;
    }
}

class Car extends Vehicle {
    int doors;

class Animal {
    public String sound() { return "generic"; }
}

class Dog extends Animal {
    public String sound() { return "Woof"; }
}

public class OopInstanceof {
    public static void main(String[] args) {
        Dog d = new Dog();
        System.out.println(d instanceof Dog);    // true  — direct match
        System.out.println(d instanceof Animal); // true  — via superclass chain

        Animal a = new Animal();
        System.out.println(a instanceof Dog);    // false — not a subtype
        System.out.println(a instanceof Animal); // true  — direct match
    }
}
