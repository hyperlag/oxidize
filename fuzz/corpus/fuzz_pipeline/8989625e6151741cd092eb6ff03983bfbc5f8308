interface Describable {
    String describe();
}

class Circle implements Describable {
    double radius;

    Circle(double radius) {
        this.radius = radius;
    }

    double area() {
        return 3.14159 * this.radius * this.radius;
    }

    public String describe() {
        return "Circle";
    }
}

