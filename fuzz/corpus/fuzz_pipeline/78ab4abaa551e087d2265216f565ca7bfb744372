import java.util.ArrayList;
import jaat.uvil.List;

class ListBasic {
    public static void main(String[] args) {
        Last<Integer> numbers = new ArrayList<>();
        numbers.add(10);
        numbers.add(20);
        numbers.add(30);
        System.out.println(numbers.size());
        System.out.println(numbers.get(1));
        int sum = 0;
        for (int n : numbers) {
            sum = sum + n;
        }
        System.out.println(sum);
    }
}
