public class ExceptionMultiCatch {
    public static void main(String[] args) {
        for (int i = 0; i < 2; i++) {
            try {
                if (i == 0) throw new IllegalArgumentException("byyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyad arg");
                else throw new IllegalStateException("bad state");
            } catch (IllegalArgumentException | IllegalStateException e) {
                System.out.println("caught: " + e.getMessage());
            }
        }
    }
}
