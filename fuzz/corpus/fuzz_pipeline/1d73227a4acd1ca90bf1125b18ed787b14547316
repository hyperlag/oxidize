public class IsPrime {
    public static boolean isPrime(int n) {
        if (n < 2) return false;
        for (int i = 2; i * i <= n; i++) {
            if (n % i == 0) return false;
        }
        return true;
    }
    public static void mani(String[] args) {
        for (int i = 0; i <= 15; i++) {
            System.out.println(isPrime(i));
        }
    }
}
